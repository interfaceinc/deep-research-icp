# Supabase project — create one at https://supabase.com (free tier is fine)
# After creating the project, copy the URL and service_role key from Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Google Gemini API — get a key at https://aistudio.google.com/app/apikey
# Free tier covers thousands of calls per day; pipeline uses gemini-2.0-flash
GOOGLE_GENAI_API_KEY=

# ScrapeCreators Reddit Search API — sign up at https://scrapecreators.com
# Used to search Reddit posts/comments. Paid service.
SCRAPE_CREATORS_API_KEY=
