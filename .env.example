# Google Gemini API — get a key at https://aistudio.google.com/app/apikey
# Free tier covers thousands of calls per day; pipeline uses gemini-2.5-flash
GOOGLE_GENAI_API_KEY=

# SerpAPI — https://serpapi.com/manage-api-key
# Reddit search runs through SerpAPI's Google engine scoped to reddit.com
SERPAPI_KEY=

# ScrapeCreators — https://scrapecreators.com (required for --platform tiktok)
SCRAPECREATORS_API_KEY=

# Local SQLite file (optional; defaults to research.db in the repo root)
RESEARCH_DB_PATH=research.db
