{
  "name": "audience-research-toolkit",
  "version": "0.2.0",
  "description": "Reddit + TikTok audience research pipeline with web UI",
  "type": "module",
  "private": true,
  "scripts": {
    "web": "node --disable-warning=ExperimentalWarning --import tsx src/server.ts",
    "start": "node --disable-warning=ExperimentalWarning --import tsx src/server.ts",
    "research:run": "node --disable-warning=ExperimentalWarning --import tsx src/scripts/research-run.ts",
    "research:query": "node --disable-warning=ExperimentalWarning --import tsx src/scripts/research-query.ts",
    "research:tiktok-verify": "node --disable-warning=ExperimentalWarning --import tsx src/scripts/tiktok-offline-verify.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "p-limit": "^6.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
